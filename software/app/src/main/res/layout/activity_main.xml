<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/pageBackground">

    <!-- ═══ BLUE HEADER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorPrimary"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <!-- Title Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <!-- App Logo -->
            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="#33FFFFFF"
                android:gravity="center"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_launcher_foreground"
                    android:contentDescription="App logo" />

            </LinearLayout>

            <!-- Title + Subtitle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smart Medicine Box"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 compartments"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- BLE Status Badge -->
            <TextView
                android:id="@+id/tvBleStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Connect"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#EF9A9A"
                android:background="#26FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- History Button -->
            <ImageView
                android:id="@+id/btnHistory"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_recent_history"
                android:background="#33FFFFFF"
                android:padding="6dp"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="History" />

        </LinearLayout>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <!-- Total -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1AFFFFFF"
                android:padding="10dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/tvTotalMedicines"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textColor="#B3FFFFFF"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Taken -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1AFFFFFF"
                android:padding="10dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/tvTakenCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#A5D6A7"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Taken"
                    android:textColor="#B3FFFFFF"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Pending -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1AFFFFFF"
                android:padding="10dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/tvPendingCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#EF9A9A"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textColor="#B3FFFFFF"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Missed -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1AFFFFFF"
                android:padding="10dp">

                <TextView
                    android:id="@+id/tvMissedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFF59D"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Missed"
                    android:textColor="#B3FFFFFF"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ═══ SCROLLABLE BODY ═══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- BLE Connection Banner -->
            <LinearLayout
                android:id="@+id/layoutBleBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/statusMissedBg"
                android:padding="12dp"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tvBannerIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️"
                    android:textSize="18sp"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvBannerTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HARDWARE NOT CONNECTED"
                        android:textColor="#E65100"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBannerDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap Connect above to pair ESP32"
                        android:textColor="#BF360C"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Next Medicine Banner -->
            <LinearLayout
                android:id="@+id/layoutNextMedicine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/statusPendingBg"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏰"
                    android:textSize="20sp"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEXT MEDICINE"
                        android:textColor="@color/colorPrimary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNextMedicine"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorPrimaryDark"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- Section Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEDICINE COMPARTMENTS"
                android:textColor="@color/sectionText"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Grid Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="10dp">

                <FrameLayout
                    android:id="@+id/comp1"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp" />

                <FrameLayout
                    android:id="@+id/comp2"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp" />

                <FrameLayout
                    android:id="@+id/comp3"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1" />

            </LinearLayout>

            <!-- Grid Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:id="@+id/comp4"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp" />

                <FrameLayout
                    android:id="@+id/comp5"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp" />

                <FrameLayout
                    android:id="@+id/comp6"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1" />

            </LinearLayout>

            <!-- Legend -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@color/statusTaken"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Taken"
                    android:textSize="11sp"
                    android:textColor="@color/sectionText"
                    android:layout_marginEnd="14dp" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@color/colorPrimary"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="11sp"
                    android:textColor="@color/sectionText"
                    android:layout_marginEnd="14dp" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@color/statusMissed"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Missed"
                    android:textSize="11sp"
                    android:textColor="@color/sectionText"
                    android:layout_marginEnd="14dp" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="#BDBDBD"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Empty"
                    android:textSize="11sp"
                    android:textColor="@color/sectionText" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>