<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/pageBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:title="Add Medicine"
        app:titleTextColor="@android:color/white"
        app:navigationIconTint="@android:color/white" />

    <!-- Compartment Badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvCompartmentBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦 Compartment 1"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="#33FFFFFF"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Medicine Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medicine Name *"
                android:textColor="@color/labelText"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etMedicineName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="e.g. Paracetamol"
                android:textColor="@color/inputText"
                android:inputType="textCapWords"
                android:background="@drawable/input_background"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp" />

            <!-- Time -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medicine Time *"
                android:textColor="@color/labelText"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/input_background"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvSelectedTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="08:00"
                    android:textSize="32sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="8dp" />

                <Button
                    android:id="@+id/btnPickTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pick Time"
                    android:backgroundTint="@color/colorPrimary"
                    android:textColor="@android:color/white"
                    android:layout_marginEnd="8dp" />

            </LinearLayout>

            <!-- Category -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category *"
                android:textColor="@color/labelText"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/input_background"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp" />

            <!-- Quantity Label -->
            <TextView
                android:id="@+id/tvQuantityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quantity (tablets) *"
                android:textColor="@color/labelText"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <!-- Quantity input + unit -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/input_background"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/etQuantity"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="e.g. 1"
                    android:textColor="@color/inputText"
                    android:inputType="number"
                    android:background="@null"
                    android:paddingHorizontal="14dp"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="tablet(s)"
                    android:textColor="@color/labelText"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:paddingEnd="14dp" />

            </LinearLayout>

            <!-- Quick select label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick select:"
                android:textColor="@color/sectionText"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <!-- Chips Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/chip1"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="1"
                    android:textSize="14sp"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/chip2"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="2"
                    android:textSize="14sp"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/chip3"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="5"
                    android:textSize="14sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

            <!-- Chips Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/chip4"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="10"
                    android:textSize="14sp"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/chip5"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="15"
                    android:textSize="14sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

            <!-- Stock Count -->
            <TextView
                android:id="@+id/tvStockLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Stock (how many you have) *"
                android:textColor="@color/labelText"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/input_background"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/etStock"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="e.g. 30"
                    android:inputType="number"
                    android:background="@null"
                    android:paddingHorizontal="14dp"
                    android:textSize="16sp"
                    android:textColor="@color/inputText" />

                <TextView
                    android:id="@+id/tvStockUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="units"
                    android:textColor="@color/labelText"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:paddingEnd="14dp" />

            </LinearLayout>

            <!-- Stock quick select chips -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick stock:"
                android:textColor="@color/sectionText"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/stockChip7"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="7"
                    android:textSize="13sp"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/stockChip14"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="14"
                    android:textSize="13sp"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/stockChip30"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="30"
                    android:textSize="13sp"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/stockChip60"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="60"
                    android:textSize="13sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveMedicine"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SAVE MEDICINE"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@android:color/white" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>