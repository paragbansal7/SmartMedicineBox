<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/cardBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Status icon circle -->
        <TextView
            android:id="@+id/tvHistoryIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:textSize="18sp"
            android:layout_marginEnd="12dp" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHistoryName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medicine Name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/inputText" />

            <TextView
                android:id="@+id/tvHistoryDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Box 1 · Tablet · 08:00"
                android:textSize="11sp"
                android:textColor="@color/sectionText"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvHistoryTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today at 08:03"
                android:textSize="11sp"
                android:textColor="@color/sectionText"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Status badge -->
        <TextView
            android:id="@+id/tvHistoryStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TAKEN"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@drawable/status_badge_background" />

    </LinearLayout>

</androidx.cardview.widget.CardView>