<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SmartMedicineBox" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/pageBackground</item>
        <item name="android:windowBackground">@color/pageBackground</item>
        <item name="android:spinnerItemStyle">@style/SpinnerItem</item>
        <item name="android:dropDownListViewStyle">@style/SpinnerDropDown</item>
    </style>

    <style name="SpinnerItem" parent="Widget.AppCompat.TextView.SpinnerItem">
        <item name="android:textColor">@color/inputText</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="SpinnerDropDown" parent="Widget.AppCompat.ListView.DropDown">
        <item name="android:background">@color/inputBackground</item>
    </style>

    <style name="ThemeOverlay_App_BottomSheetDialog"
        parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AppBottomSheetStyle</item>
    </style>

    <style name="AppBottomSheetStyle"
        parent="Widget.MaterialComponents.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/AppBottomSheetCorners</item>
    </style>

    <style name="AppBottomSheetCorners">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>

</resources>